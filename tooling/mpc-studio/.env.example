#
# MPC Studio (Vite) environment variables
#
# Copy to `.env.local` for local overrides.
#

# Emergency kill switch for trace v2 UI (falls back to legacy trace mode).
VITE_WORKFLOW_TRACE_V2=false

# Local worker input limits for FormPackage generation (bytes).
VITE_MPC_FORM_MAX_DSL_BYTES=256000
VITE_MPC_FORM_MAX_DATA_BYTES=64000
VITE_MPC_FORM_MAX_ACTOR_BYTES=32000

# Expression/ACL fail-open in Pyodide (true = on error treat visibility/validation as pass; enterprise may set false).
VITE_MPC_FORM_FAIL_OPEN=true

# Strict structural validation (FormDef/FieldDef) in Studio local worker.
VITE_MPC_STRICT_VALIDATION=false

# Max wall time for Pyodide form package generation (ms).
VITE_MPC_FORM_PACKAGE_TIMEOUT_MS=30000

# Optional override for Pyodide CDN base URL (must end with `/full/`).
VITE_PYODIDE_CDN_URL=

