{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Intent",
  "type": "object",
  "required": [
    "kind"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "minLength": 1,
      "description": "Intent kind. MUST be a value defined in INTENT_TAXONOMY.md. Unknown kinds fail conformance."
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "params": {
      "type": "object"
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
