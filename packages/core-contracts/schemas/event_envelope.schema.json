{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EventEnvelope",
  "type": "object",
  "required": [
    "name",
    "kind",
    "timestamp",
    "actor",
    "object"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "create",
        "update",
        "delete",
        "transition",
        "custom"
      ]
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "object",
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "user",
            "service",
            "system"
          ]
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "claims": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "object": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "attributes": {
          "type": "object"
        },
        "state": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object"
    },
    "payload": {
      "type": "object"
    },
    "previous": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
