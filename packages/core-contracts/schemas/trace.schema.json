{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trace",
  "type": "object",
  "required": [
    "spanId",
    "engine",
    "events"
  ],
  "properties": {
    "spanId": {
      "type": "string",
      "minLength": 1
    },
    "parentSpanId": {
      "type": "string",
      "minLength": 1
    },
    "engine": {
      "type": "string",
      "minLength": 1
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "t"
        ],
        "properties": {
          "t": {
            "type": "string",
            "minLength": 1
          },
          "at": {
            "type": "string",
            "minLength": 1
          },
          "data": {
            "type": "object"
          },
          "result": {
            "type": "object"
          },
          "durationMs": {
            "type": "number",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
